{
  "name": "resume-master",
  "version": "5.0.0",
  "description": "ATS-optimised resume generator — multi-user, apply modes, ghost filtering, Excel export, autofill extension",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "build": "cd client && npm install && npm run build",
    "setup": "npm install && npm run build",
    "postinstall": "npx playwright install chromium --with-deps",
    "migrate": "node scripts/migrate.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/backup.js restore"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@sparticuz/chromium": "^143.0.4",
    "apify-client": "^2.22.3",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "connect-sqlite3": "^0.9.13",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "multer": "^2.0.0",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "playwright": "^1.59.1",
    "puppeteer-core": "^24.40.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
