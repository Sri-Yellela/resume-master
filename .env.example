PORT=3001
APP_BASE_URL=http://localhost:3001
SESSION_SECRET=replace-with-a-long-random-secret
PASSWORD_RESET_SECRET=replace-with-a-long-random-secret
COOKIE_ENCRYPTION_KEY=replace-with-64-hex-chars

# Google OAuth sign-in / integration linking
# Google Cloud Console authorized redirect URI must exactly match this value.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback

# LinkedIn OpenID Connect sign-in / integration linking
# LinkedIn app authorized redirect URI must exactly match this value.
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/oauth/linkedin/callback
