{
  "manifest_version": 3,
  "name": "Resume Master Importer",
  "version": "0.1.0",
  "description": "Import LinkedIn jobs into Resume Master.",
  "permissions": ["activeTab", "storage", "tabs", "cookies", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Resume Master Importer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["linkedin-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*",
        "https://*.up.railway.app/*"
      ],
      "js": ["app-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
