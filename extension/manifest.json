{
  "manifest_version": 3,
  "name": "Resume Master Importer",
  "version": "0.1.0",
  "description": "Import your own saved jobs into Resume Master.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "action": {
    "default_title": "Resume Master Importer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
